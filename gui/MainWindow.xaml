<Window
    x:Class="LTOG.Gui.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:LTOG.Gui.Core"
    xmlns:local="using:LTOG.Gui"
    Title="LTOG">

    <Grid x:Name="Root">
        <Grid.Resources>
            <Style x:Key="Card" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="16" />
            </Style>
            <Style x:Key="SectionHeader" TargetType="TextBlock"
                   BasedOn="{StaticResource BodyStrongTextBlockStyle}">
                <Setter Property="Margin" Value="2,0,0,8" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <InfoBar x:Name="EnvBar" Grid.Row="0" Margin="12,8,12,0"
                 IsOpen="False" Severity="Error" IsClosable="False"
                 Visibility="Collapsed" />

        <NavigationView x:Name="Nav" Grid.Row="1"
                        PaneDisplayMode="Left" OpenPaneLength="156"
                        IsBackButtonVisible="Collapsed" IsSettingsVisible="False"
                        IsPaneToggleButtonVisible="False"
                        SelectionChanged="Nav_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="MountNavItem" Content="Tape Drives" Tag="mount" IsSelected="True">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8CE;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Indexes" Tag="index">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8F1;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Log" Tag="log">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7C3;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Settings" Tag="settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="About" Tag="about">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE946;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Grid x:Name="PagesHost" SizeChanged="PagesHost_SizeChanged">
                <!-- ==================== Mounting ==================== -->
                <ScrollViewer x:Name="MountPanel" Padding="16,0">
                    <StackPanel x:Name="MountContent" Spacing="12" HorizontalAlignment="Center" Margin="0,12">
                        <TextBlock x:Name="NoDrivesText" Text="No tape drives found."
                                   Opacity="0.6" Margin="2,0" Visibility="Collapsed" />
                        <ItemsControl x:Name="DrivesList" ItemsSource="{x:Bind Slots}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:DriveSlot">
                                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                                        <StackPanel Spacing="12">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="{x:Bind DriveDisplay}" IsTextSelectionEnabled="True"
                                                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon Glyph="&#xE958;" FontSize="13" Opacity="0.7"
                                                                  VerticalAlignment="Center" Margin="0,1,0,0" />
                                                        <TextBlock Text="{x:Bind CartridgeText, Mode=OneWay}" IsTextSelectionEnabled="True"
                                                                   FontSize="12" Opacity="0.75"
                                                                   VerticalAlignment="Center" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                            Spacing="8" VerticalAlignment="Center">
                                                    <Button Width="42" Height="38" Padding="0"
                                                            ToolTipService.ToolTip="{x:Bind EjectLoadTooltip, Mode=OneWay}"
                                                            IsEnabled="{x:Bind EjectLoadEnabled, Mode=OneWay}"
                                                            Click="SlotEjectLoad_Click">
                                                        <Grid>
                                                            <FontIcon Glyph="{x:Bind EjectLoadGlyph, Mode=OneWay}" FontSize="16"
                                                                      Visibility="{x:Bind EjectLoadGlyphVisibility, Mode=OneWay}" />
                                                            <ProgressRing IsActive="{x:Bind MediaOpRunning, Mode=OneWay}"
                                                                          Width="16" Height="16"
                                                                          Visibility="{x:Bind EjectLoadSpinnerVisibility, Mode=OneWay}" />
                                                        </Grid>
                                                    </Button>
                                                    <Button Width="42" Height="38" Padding="0"
                                                            ToolTipService.ToolTip="Refresh drive, cartridge and free letters"
                                                            IsEnabled="{x:Bind RefreshEnabled, Mode=OneWay}"
                                                            Click="SlotRefreshCard_Click">
                                                        <Grid>
                                                            <FontIcon Glyph="&#xE72C;" FontSize="16"
                                                                      Visibility="{x:Bind RefreshGlyphVisibility, Mode=OneWay}" />
                                                            <ProgressRing IsActive="{x:Bind RefreshRunning, Mode=OneWay}"
                                                                          Width="16" Height="16"
                                                                          Visibility="{x:Bind RefreshSpinnerVisibility, Mode=OneWay}" />
                                                        </Grid>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>

                                            <Border Height="1" Margin="-16,4"
                                                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Drive letter" VerticalAlignment="Center" />
                                                <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                          ItemsSource="{x:Bind Letters}"
                                                          SelectedIndex="{x:Bind SelectedLetterIndex, Mode=TwoWay}"
                                                          IsEnabled="{x:Bind OptionsEnabled, Mode=OneWay}" />
                                                <Button Grid.Column="2"
                                                        Style="{x:Bind ButtonStyle, Mode=OneWay}"
                                                        MinWidth="0"
                                                        VerticalAlignment="Center"
                                                        IsEnabled="{x:Bind ButtonEnabled, Mode=OneWay}"
                                                        Click="SlotAction_Click">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ProgressRing IsActive="{x:Bind IsBusy, Mode=OneWay}"
                                                                      Width="16" Height="16"
                                                                      Visibility="{x:Bind SpinnerVisibility, Mode=OneWay}" />
                                                        <TextBlock Text="{x:Bind ButtonText, Mode=OneWay}" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>

                                            <StackPanel Orientation="Horizontal" Spacing="24">
                                                <CheckBox Content="Mount read-only"
                                                          IsChecked="{x:Bind ReadOnlyChecked, Mode=OneWay}"
                                                          IsEnabled="{x:Bind OptionsEnabled, Mode=OneWay}"
                                                          Click="SlotReadOnly_Click" />
                                                <CheckBox Content="Eject cartridge after unmount"
                                                          IsChecked="{x:Bind EjectChecked, Mode=OneWay}"
                                                          IsEnabled="{x:Bind OptionsEnabled, Mode=OneWay}"
                                                          Click="SlotEject_Click" />
                                                <CheckBox Content="Remount at system start-up"
                                                          IsChecked="{x:Bind RemountChecked, Mode=OneWay}"
                                                          IsEnabled="{x:Bind RemountEnabled, Mode=OneWay}"
                                                          Click="SlotRemount_Click" />
                                            </StackPanel>

                                            <!-- cartridge controls (disabled while mounted) -->
                                            <Border Height="1" Margin="-16,4"
                                                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                                            <StackPanel Orientation="Horizontal" Spacing="6"
                                                        HorizontalAlignment="Right"
                                                        Visibility="{x:Bind MountedNoticeVisibility, Mode=OneWay}">
                                                <FontIcon Glyph="&#xE946;" FontSize="13" Opacity="0.7"
                                                          VerticalAlignment="Center" Margin="0,1,0,0" />
                                                <TextBlock Text="Cannot be used while mounted"
                                                           FontSize="12" Opacity="0.75"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Button Content="Format..." HorizontalAlignment="Stretch"
                                                        IsEnabled="{x:Bind OptionsEnabled, Mode=OneWay}"
                                                        Click="SlotFormat_Click" />
                                                <Button Grid.Column="1" Content="Unformat..." HorizontalAlignment="Stretch"
                                                        IsEnabled="{x:Bind OptionsEnabled, Mode=OneWay}"
                                                        Click="SlotUnformat_Click" />
                                                <Button Grid.Column="2" Content="Check" HorizontalAlignment="Stretch"
                                                        IsEnabled="{x:Bind OptionsEnabled, Mode=OneWay}"
                                                        Click="SlotCheck_Click" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- ==================== Indexes ==================== -->
                <ScrollViewer x:Name="IndexPanel" Padding="16,0" Visibility="Collapsed">
                    <StackPanel x:Name="IndexContent" Spacing="12" HorizontalAlignment="Center" Margin="0,12">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Content="Open folder" Click="OpenWorkFolder_Click" />
                            <Button Grid.Column="1" Content="Refresh" Click="RefreshSchemas_Click" />
                            <ComboBox x:Name="SchemaSortCombo" Grid.Column="3" MinWidth="170"
                                      SelectionChanged="SchemaSort_Changed">
                                <ComboBoxItem Content="Name (A–Z)" />
                                <ComboBoxItem Content="Name (Z–A)" />
                                <ComboBoxItem Content="Newest captured" />
                                <ComboBoxItem Content="Oldest captured" />
                            </ComboBox>
                        </Grid>
                        <TextBlock x:Name="NoSchemasText" Text="No captured indexes yet."
                                   Opacity="0.6" Margin="2,0" />
                        <ItemsControl x:Name="SchemaList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:SchemaItem">
                                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="1">
                                                <TextBlock Text="{x:Bind Title}"
                                                           Style="{StaticResource BodyStrongTextBlockStyle}"
                                                           IsTextSelectionEnabled="True" />
                                                <TextBlock Text="{x:Bind GenLine}" FontSize="12"
                                                           Opacity="0.75" TextWrapping="Wrap"
                                                           IsTextSelectionEnabled="True" />
                                                <TextBlock Text="{x:Bind CaptureLine}" FontSize="12"
                                                           Opacity="0.75" TextWrapping="Wrap"
                                                           IsTextSelectionEnabled="True" />
                                                <TextBlock Text="{x:Bind Uuid}" FontSize="11"
                                                           Opacity="0.5" TextWrapping="Wrap"
                                                           IsTextSelectionEnabled="True" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Open"
                                                    VerticalAlignment="Center"
                                                    Click="SchemaOpen_Click" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- ==================== Log ==================== -->
                <Grid x:Name="LogPanel" Margin="0,12" HorizontalAlignment="Center"
                      Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- toolbar -->
                    <Grid Margin="2,0,2,10" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Activity log" Style="{StaticResource SectionHeader}" Margin="0" />
                            <TextBlock Text="Every LTFS, WinFsp and tape-drive call — full command line, output and result."
                                       FontSize="12" Opacity="0.65" TextWrapping="Wrap"
                                       IsTextSelectionEnabled="True" />
                        </StackPanel>
                        <CheckBox x:Name="AutoScrollCheck" Grid.Column="1" Content="Auto-scroll"
                                  IsChecked="True" VerticalAlignment="Center" />
                        <Button Grid.Column="2" Content="Open log file"
                                VerticalAlignment="Center" Click="OpenLogFile_Click" />
                        <Button Grid.Column="3" Content="Clear"
                                VerticalAlignment="Center" Click="ClearLog_Click" />
                    </Grid>

                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                        <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto" Padding="10">
                            <StackPanel>
                                <TextBlock x:Name="NoLogText" Text="No activity yet." Opacity="0.6" Margin="4"
                                           Visibility="{x:Bind Activity.EmptyHint, Mode=OneWay}" />
                                <ItemsControl ItemsSource="{x:Bind Activity.Entries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="local:LogEntry">
                                            <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1" CornerRadius="6" Margin="0,0,0,8">
                                                <Grid>
                                                    <!-- per-kind accent bar -->
                                                    <Border Width="3" HorizontalAlignment="Left"
                                                            CornerRadius="6,0,0,6"
                                                            Background="{x:Bind AccentBrush}" />
                                                    <StackPanel Margin="14,9,12,10" Spacing="7">
                                                        <!-- header: icon · title · time -->
                                                        <Grid ColumnSpacing="8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <FontIcon Glyph="{x:Bind Glyph}" FontSize="15"
                                                                      Foreground="{x:Bind AccentBrush}"
                                                                      VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="1" Text="{x:Bind Title}"
                                                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                                                       TextWrapping="Wrap" IsTextSelectionEnabled="True"
                                                                       VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="2" Text="{x:Bind Timestamp}"
                                                                       FontFamily="Consolas" FontSize="12" Opacity="0.55"
                                                                       VerticalAlignment="Center" />
                                                        </Grid>

                                                        <!-- full command line -->
                                                        <Border Visibility="{x:Bind CommandVisibility}"
                                                                Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                                BorderThickness="1" CornerRadius="4" Padding="9,7">
                                                            <StackPanel Spacing="3">
                                                                <TextBlock FontFamily="Consolas" FontSize="12.5"
                                                                           TextWrapping="Wrap" IsTextSelectionEnabled="True">
                                                                    <Run Text="$ " Foreground="{x:Bind AccentBrush}" />
                                                                    <Run Text="{x:Bind CommandLine}" />
                                                                </TextBlock>
                                                                <TextBlock Visibility="{x:Bind WorkingDirVisibility}"
                                                                           Text="{x:Bind WorkingDirText}"
                                                                           FontFamily="Consolas" FontSize="11" Opacity="0.55"
                                                                           TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                                                            </StackPanel>
                                                        </Border>

                                                        <!-- streamed output -->
                                                        <Border Visibility="{x:Bind OutputVisibility, Mode=OneWay}"
                                                                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                                CornerRadius="4" Padding="9,6">
                                                            <ItemsControl ItemsSource="{x:Bind Lines}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate x:DataType="local:LogLine">
                                                                        <TextBlock Text="{x:Bind Text}"
                                                                                   Foreground="{x:Bind Brush}"
                                                                                   FontFamily="Consolas" FontSize="12"
                                                                                   TextWrapping="Wrap"
                                                                                   IsTextSelectionEnabled="True" />
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </Border>

                                                        <!-- result footer -->
                                                        <StackPanel Orientation="Horizontal" Spacing="8"
                                                                    Visibility="{x:Bind ResultVisibility}">
                                                            <ProgressRing Width="15" Height="15"
                                                                          IsActive="{x:Bind Running, Mode=OneWay}"
                                                                          Visibility="{x:Bind SpinnerVisibility, Mode=OneWay}" />
                                                            <Border CornerRadius="9" Padding="9,2"
                                                                    VerticalAlignment="Center"
                                                                    Background="{x:Bind StatusBrush, Mode=OneWay}">
                                                                <TextBlock Text="{x:Bind StatusText, Mode=OneWay}"
                                                                           FontSize="10.5" FontWeight="SemiBold"
                                                                           Foreground="White" />
                                                            </Border>
                                                            <TextBlock Text="{x:Bind ResultDetail, Mode=OneWay}"
                                                                       FontSize="12" Opacity="0.7"
                                                                       VerticalAlignment="Center" TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- ==================== Settings ==================== -->
                <ScrollViewer x:Name="SettingsPanel" Padding="16,0" Visibility="Collapsed">
                    <StackPanel x:Name="SettingsContent" Spacing="12" HorizontalAlignment="Center" Margin="0,12">
                        <StackPanel>
                            <TextBlock Text="Index capture" Style="{StaticResource SectionHeader}" />
                            <Border Style="{StaticResource Card}">
                                <StackPanel Spacing="10">
                                    <CheckBox x:Name="CaptureIndexCheck"
                                              Content="Capture snapshot of index at mount/unmount time"
                                              IsChecked="True" Click="SettingChanged" />
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Working folder" VerticalAlignment="Center" />
                                        <TextBox x:Name="WorkFolderBox" Grid.Column="1" Text="C:\tmp\ltfs"
                                                 LostFocus="SettingChanged" />
                                    </Grid>
                                    <TextBlock IsTextSelectionEnabled="True" Text="Snapshots are plain LTFS index XML — off-tape backups of the volume's metadata. Browse them on the Indexes page."
                                               FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Index updates" Style="{StaticResource SectionHeader}" />
                            <Border Style="{StaticResource Card}">
                                <StackPanel Spacing="8">
                                    <CheckBox x:Name="OverridePolicyCheck"
                                              Content="Override default index update policy"
                                              Click="SettingChanged" />
                                    <RadioButton x:Name="PolicyDismountRadio" GroupName="SyncPolicy"
                                                 Content="when volume is dismounted" Margin="24,0,0,0"
                                                 IsEnabled="False" Click="SettingChanged" />
                                    <RadioButton x:Name="PolicyPeriodicRadio" GroupName="SyncPolicy"
                                                 IsChecked="True" Margin="24,0,0,0"
                                                 IsEnabled="False" Click="SettingChanged">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="periodically, every" VerticalAlignment="Center" />
                                            <NumberBox x:Name="PeriodBox" Minimum="1" Maximum="1440"
                                                       SmallChange="1" SpinButtonPlacementMode="Compact"
                                                       ValueChanged="Period_ValueChanged" />
                                            <TextBlock Text="minutes" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </RadioButton>
                                    <TextBlock FontSize="12" Opacity="0.65" TextWrapping="Wrap"
                                               IsTextSelectionEnabled="True" Text="Default policy: the index is written to tape every time a modified file is closed (sync_type=close)." />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- ==================== About ==================== -->
                <ScrollViewer x:Name="AboutPanel" Padding="16,0" Visibility="Collapsed">
                    <StackPanel x:Name="AboutContent" Spacing="12" HorizontalAlignment="Center" Margin="0,12">
                        <Border Style="{StaticResource Card}">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Image x:Name="AboutIcon" Width="120" Height="120"
                                       VerticalAlignment="Top" />
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="LTOG" FontSize="28" IsTextSelectionEnabled="True" FontWeight="SemiBold" />
                                        <Border CornerRadius="12" Padding="10,4"
                                                VerticalAlignment="Center"
                                                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1">
                                            <TextBlock x:Name="AboutVersionText" Text="v0.0.0" IsTextSelectionEnabled="True"
                                                       FontSize="14" FontWeight="SemiBold" Opacity="0.9" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="LTFS for Windows, presented through WinFsp" IsTextSelectionEnabled="True"
                                               Opacity="0.8" TextWrapping="Wrap" />
                                    <TextBlock x:Name="AboutBuildText" IsTextSelectionEnabled="True" FontSize="12" Opacity="0.65"
                                               TextWrapping="Wrap" Margin="0,6,0,0" />
                                    <Button Padding="4" Margin="-4,2,0,0" Background="Transparent"
                                            BorderThickness="0" HorizontalAlignment="Left"
                                            ToolTipService.ToolTip="github.com/rlaphoenix/LTOG"
                                            Click="GitHub_Click">
                                        <Viewbox Width="20" Height="20">
                                            <PathIcon Data="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
                                        </Viewbox>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel>
                            <TextBlock Text="Components" Style="{StaticResource SectionHeader}" />
                            <Border Style="{StaticResource Card}">
                                <StackPanel Spacing="6">
                                    <TextBlock x:Name="AboutLtfsText" IsTextSelectionEnabled="True" Text="LTFS engine: —"
                                               TextWrapping="Wrap" />
                                    <TextBlock x:Name="AboutWinFspText" IsTextSelectionEnabled="True" Text="WinFsp: —"
                                               TextWrapping="Wrap" />
                                    <TextBlock x:Name="AboutRuntimeText" IsTextSelectionEnabled="True" Text="Runtime: —"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Credits" Style="{StaticResource SectionHeader}" />
                            <Border Style="{StaticResource Card}">
                                <StackPanel Spacing="8">
                                    <TextBlock TextWrapping="Wrap" Opacity="0.85" IsTextSelectionEnabled="True"
                                               Text="IBM — the original Linear Tape File System (libltfs and core utilities, IBM Almaden Research)." />
                                    <TextBlock TextWrapping="Wrap" Opacity="0.85" IsTextSelectionEnabled="True"
                                               Text="Hewlett-Packard / HPE — the Windows port and the ltotape drive backend." />
                                    <TextBlock TextWrapping="Wrap" Opacity="0.85" IsTextSelectionEnabled="True"
                                               Text="OSR Open Systems Resources — the original Windows FUSE integration in the HP tree." />
                                    <TextBlock TextWrapping="Wrap" Opacity="0.85" IsTextSelectionEnabled="True"
                                               Text="AMIA Open Source — for preserving the HP LTFS source tree after HPE stopped distributing it." />
                                    <TextBlock TextWrapping="Wrap" Opacity="0.85" IsTextSelectionEnabled="True"
                                               Text="Bill Zissimopoulos — WinFsp, whose FUSE-compatible layer and signed driver make this approach possible." />
                                    <TextBlock TextWrapping="Wrap" Opacity="0.65" FontSize="12"
                                               IsTextSelectionEnabled="True" Text="Assistance with porting and orchestration by Claude (Anthropic)." />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="License" Style="{StaticResource SectionHeader}" />
                            <Border Style="{StaticResource Card}">
                                <StackPanel Spacing="8">
                                    <TextBlock TextWrapping="Wrap" Opacity="0.85" IsTextSelectionEnabled="True"
                                               Text="LTOG is free software under the GNU General Public License v3.0." />
                                    <TextBlock TextWrapping="Wrap" Opacity="0.85" IsTextSelectionEnabled="True"
                                               Text="It bundles third-party components under their own licenses: WinFsp (GPLv3 with FLOSS exception); the IBM/HP LTFS engine and GNU libiconv (LGPL-2.1); libxml2, ICU, zlib and the MinGW-w64 runtimes (permissive); the GCC runtime (GPLv3 with the Runtime Library Exception); the Microsoft Windows App SDK (Microsoft Software License Terms); and the .NET 8 runtime (MIT)." />
                                    <TextBlock TextWrapping="Wrap" Opacity="0.65" FontSize="12" IsTextSelectionEnabled="True"
                                               Text="Full per-component notices and license texts ship in this install (THIRD-PARTY-NOTICES.md and the licenses folder)." />
